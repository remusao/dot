[global]
    font = DejaVu Sans Mono 10
    markup = full
    format = "<b>%s</b>\n%b"
    sort = yes
    indicate_hidden = yes
    alignment = left
    show_age_threshold = 60
    word_wrap = yes
    ellipsize = middle
    width = 350
    height = 200
    origin = top-right
    offset = 10x40
    idle_threshold = 120
    follow = mouse
    sticky_history = yes
    history_length = 20
    show_indicators = yes
    stack_duplicates = true
    hide_duplicate_count = false
    icon_position = left
    min_icon_size = 32
    max_icon_size = 48
    corner_radius = 4
    progress_bar = true
    progress_bar_height = 10
    progress_bar_frame_width = 1
    progress_bar_min_width = 150
    progress_bar_max_width = 300
    mouse_left_click = close_current
    mouse_right_click = close_all
    mouse_middle_click = do_action

[urgency_low]
    background = "#222222"
    foreground = "#888888"
    timeout = 5

[urgency_normal]
    background = "#285577"
    foreground = "#ffffff"
    timeout = 10

[urgency_critical]
    background = "#900000"
    foreground = "#ffffff"
    timeout = 0
